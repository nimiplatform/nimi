{
  "compilerOptions": {
    "paths": {
      "@runtime/*": ["./src/runtime/*"],
      "@renderer/*": ["./src/shell/renderer/*"],
      "@nimiplatform/sdk": ["../../sdk/src/index.ts"],
      "@nimiplatform/sdk/*": ["../../sdk/src/*"],
      "@nimiplatform/nimi-kit/ui": ["../../kit/ui/src/index.ts"],
      "@nimiplatform/nimi-kit/ui/*": ["../../kit/ui/src/*"],
      "@nimiplatform/nimi-kit/auth": ["../../kit/auth/src/index.ts"],
      "@nimiplatform/nimi-kit/auth/*": ["../../kit/auth/src/*"],
      "@nimiplatform/nimi-kit/core/*": ["../../kit/core/src/*"],
      "@nimiplatform/nimi-kit/features/chat": ["../../kit/features/chat/src/index.ts"],
      "@nimiplatform/nimi-kit/features/chat/*": ["../../kit/features/chat/src/*"],
      "@nimiplatform/nimi-kit/features/model-picker": ["../../kit/features/model-picker/src/index.ts"],
      "@nimiplatform/nimi-kit/features/model-picker/*": ["../../kit/features/model-picker/src/*"],
      "@nimiplatform/nimi-kit/features/generation": ["../../kit/features/generation/src/index.ts"],
      "@nimiplatform/nimi-kit/features/generation/*": ["../../kit/features/generation/src/*"]
    },
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "strictPropertyInitialization": true,
    "useUnknownInCatchVariables": true,
    "exactOptionalPropertyTypes": false,
    "noUncheckedIndexedAccess": true,
    "noPropertyAccessFromIndexSignature": false,
    "noEmit": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "types": ["node", "vite/client", "react", "react-dom"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "test/**/*.d.ts",
    "test/**/*.ts",
    "vite.config.ts"
  ]
}
