{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "paths": {
      "@runtime/*": ["src/runtime/*"],
      "@renderer/*": ["src/shell/renderer/*"],
      "react": ["node_modules/react/index.js"],
      "react/jsx-runtime": ["node_modules/react/jsx-runtime.js"],
      "react/jsx-dev-runtime": ["node_modules/react/jsx-dev-runtime.js"],
      "react-dom": ["node_modules/react-dom/index.js"],
      "react-dom/client": ["node_modules/react-dom/client.js"],
      "react-dom/server": ["node_modules/react-dom/server.node.js"],
      "@nimiplatform/sdk": ["../../sdk/src/index.ts"],
      "@nimiplatform/sdk/*": ["../../sdk/src/*"],
      "@nimiplatform/nimi-ui": ["../_libs/nimi-ui/src/index.ts"],
      "@nimiplatform/nimi-ui/*": ["../_libs/nimi-ui/src/*"],
      "@nimiplatform/shell-auth": ["../_libs/shell-auth/src/index.ts"],
      "@nimiplatform/shell-auth/*": ["../_libs/shell-auth/src/*"],
      "@nimiplatform/shell-core/*": ["../_libs/shell-core/src/*"]
    }
  }
}
