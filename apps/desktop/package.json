{
  "name": "@nimiplatform/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/ensure-rust.mjs",
    "dev": "pnpm run dev:shell",
    "env:check:runtime-mods-dir": "node scripts/dev-env-check.mjs --require-runtime-mods-dir",
    "env:check:mods-root": "node scripts/env-check-mods-root.mjs",
    "dev:renderer": "vite --host 127.0.0.1 --port 1420 --strictPort",
    "dev:shell": "tauri dev --config src-tauri/tauri.conf.json",
    "dev:shell:clean": "pnpm run clean:src-js && pnpm run dev:shell",
    "smoke:mods": "pnpm run env:check:runtime-mods-dir && node scripts/dev-mods-smoke.mjs --all",
    "smoke:mod:installed": "pnpm run env:check:runtime-mods-dir && node scripts/dev-mods-smoke.mjs",
    "debug:dashscope-tts-voices": "node scripts/debug-dashscope-tts-voices.mjs",
    "clean:src-js": "find src -type f -name '*.js' -delete",
    "prepare:runtime-bundle": "node scripts/prepare-runtime-bundle.mjs",
    "check:version-sync": "node scripts/check-version-sync.mjs",
    "check:desktop-release-sync": "node scripts/check-desktop-release-sync.mjs",
    "check:desktop-updater-artifacts": "node scripts/check-desktop-updater-artifacts.mjs",
    "report:desktop-release-evidence": "node scripts/generate-desktop-release-evidence.mjs",
    "report:desktop-e2e-evidence": "node scripts/generate-desktop-e2e-evidence.mjs",
    "build:renderer": "vite build",
    "typecheck": "tsc --noEmit",
    "build": "pnpm run typecheck && pnpm run build:renderer && pnpm run prepare:runtime-bundle && pnpm run check:version-sync && pnpm run check:desktop-release-sync && (cd src-tauri && cargo check)",
    "lint": "pnpm run check:version-sync && pnpm run typecheck && eslint . --max-warnings 0 && (cd src-tauri && cargo check)",
    "test:quality": "pnpm run i18n:check && pnpm run i18n:audit && pnpm run lint",
    "test:unit:i18n": "node scripts/run-unit-tests.mjs --i18n",
    "test:unit:rest": "node scripts/run-unit-tests.mjs --rest",
    "test:unit": "pnpm run test:unit:i18n && pnpm run test:unit:rest",
    "test:e2e:smoke": "node scripts/run-e2e.mjs --suite smoke",
    "test:e2e:journeys": "node scripts/run-e2e.mjs --suite journeys",
    "test:e2e": "node scripts/run-e2e.mjs --suite all",
    "test:e2e:ci": "node scripts/run-e2e.mjs --suite smoke",
    "test": "pnpm run test:quality && pnpm run test:unit",
    "i18n:check": "node scripts/i18n-check.mjs",
    "i18n:audit": "node scripts/i18n-audit.mjs",
    "i18n:sync": "node scripts/i18n-sync.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.1",
    "@tauri-apps/cli": "^2.10.1",
    "@wdio/cli": "^9.26.1",
    "@wdio/local-runner": "^9.26.1",
    "@wdio/mocha-framework": "^9.26.1",
    "@wdio/spec-reporter": "^9.26.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "esbuild": "^0.27.4",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "socket.io": "^4.8.3",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.3.1",
    "webdriverio": "^9.26.1"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "2.0.35",
    "@nimiplatform/sdk": "workspace:*",
    "@nimiplatform/nimi-ui": "workspace:*",
    "@nimiplatform/shell-auth": "workspace:*",
    "@nimiplatform/shell-core": "workspace:*",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "@tanstack/react-query": "^5.90.21",
    "@types/three": "^0.183.1",
    "ai": "6.0.116",
    "ajv": "^8.18.0",
    "i18next": "^25.8.18",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-i18next": "^16.5.8",
    "react-router-dom": "^7.13.1",
    "scheduler": "^0.27.0",
    "simplex-noise": "^4.0.3",
    "socket.io-client": "^4.8.3",
    "three": "^0.183.2",
    "use-sync-external-store": "^1.6.0",
    "zod": "4.3.6",
    "zustand": "^5.0.12"
  }
}
