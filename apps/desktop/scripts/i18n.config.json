{
  "supportedLocales": [
    "en",
    "zh"
  ],
  "modPolicies": {},
  "audit": {
    "scopeDirs": [
      "src/shell/renderer",
      "src/shell/renderer/index.html"
    ],
    "extensions": [
      ".ts",
      ".tsx",
      ".html"
    ],
    "excludePathPatterns": [
      "/test/",
      ".test.",
      ".spec.",
      "settings-assets.tsx"
    ],
    "allowTextPatterns": [
      "^MOD$",
      "^CRASH$",
      "^You$",
      "^Agent$",
      "^Human$",
      "^Error$",
      "^unknown$",
      "^-$",
      "^--$",
      "^[A-Z0-9_]+$",
      "^MetaMask$",
      "^Binance Wallet$",
      "^OKX Wallet$",
      "^Google$",
      "^Google login$",
      "^Nimi$"
    ]
  }
}
