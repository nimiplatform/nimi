{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nimi Lookdev",
  "version": "0.1.0",
  "identifier": "app.nimi.lookdev",
  "build": {
    "beforeDevCommand": "pnpm --filter @nimiplatform/lookdev run dev:renderer",
    "beforeBuildCommand": "pnpm --filter @nimiplatform/lookdev run build:renderer",
    "devUrl": "http://127.0.0.1:1423",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Nimi Lookdev",
        "url": "/",
        "width": 1440,
        "height": 900,
        "minWidth": 1120,
        "minHeight": 780,
        "decorations": true,
        "resizable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 14,
          "y": 24
        }
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc:; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: file:; media-src 'self' data: blob: file:; font-src 'self' data:; connect-src 'self' https: http://127.0.0.1:* http://localhost:* ws://127.0.0.1:* ws://localhost:*;"
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  }
}
