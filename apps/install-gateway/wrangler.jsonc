{
  "name": "nimi-install-gateway",
  "main": "src/index.mjs",
  "compatibility_date": "2026-03-16",
  "routes": [
    {
      "pattern": "install.nimi.xyz",
      "custom_domain": true
    }
  ],
  "assets": {
    "binding": "ASSETS",
    "directory": "dist/assets",
    "run_worker_first": true
  }
}
