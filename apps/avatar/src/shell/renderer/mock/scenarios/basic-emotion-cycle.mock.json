    { "kind": "time", "at_ms":  7000, "type": "runtime.agent.presentation.activity_requested", "detail": { "activity_name": "sad",         "category": "emotion", "intensity": "moderate", "source": "mock" } },
    { "kind": "time", "at_ms":  9000, "type": "runtime.agent.presentation.activity_requested", "detail": { "activity_name": "surprised",   "category": "emotion", "intensity": "strong",   "source": "mock" } },
    { "kind": "time", "at_ms": 11000, "type": "runtime.agent.presentation.activity_requested", "detail": { "activity_name": "shy",         "category": "emotion", "intensity": "moderate", "source": "mock" } },
    { "kind": "time", "at_ms": 13000, "type": "runtime.agent.presentation.activity_requested", "detail": { "activity_name": "angry",       "category": "emotion", "intensity": "moderate", "source": "mock" } },
    { "kind": "time", "at_ms": 15000, "type": "runtime.agent.presentation.activity_requested", "detail": { "activity_name": "confused",    "category": "emotion", "intensity": "moderate", "source": "mock" } },
    { "kind": "time", "at_ms": 17000, "type": "runtime.agent.presentation.activity_requested", "detail": { "activity_name": "excited",     "category": "emotion", "intensity": "strong",   "source": "mock" } },
    { "kind": "time", "at_ms": 19000, "type": "runtime.agent.presentation.activity_requested", "detail": { "activity_name": "worried",     "category": "emotion", "intensity": "weak",     "source": "mock" } },
    { "kind": "time", "at_ms": 21000, "type": "runtime.agent.presentation.activity_requested", "detail": { "activity_name": "embarrassed", "category": "emotion", "intensity": "moderate", "source": "mock" } }
