{
  "name": "@nimiplatform/avatar",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:renderer": "vite --host 127.0.0.1 --port 1427 --strictPort",
    "dev:shell": "tauri dev --config src-tauri/tauri.conf.json",
    "build:renderer": "vite build",
    "check:bundle-runtime-imports": "node scripts/check-avatar-bundle-runtime-imports.mjs",
    "smoke:agent-center-live2d": "node scripts/smoke-agent-center-live2d.mjs",
    "typecheck": "tsc --noEmit",
    "build": "pnpm run typecheck && pnpm run build:renderer && (cd src-tauri && cargo check)",
    "lint": "pnpm run typecheck && eslint . --max-warnings 0 && (cd src-tauri && cargo check)",
    "check:spec-consistency": "npx tsx scripts/check-avatar-spec-consistency.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.1",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.3.1",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@nimiplatform/nimi-kit": "workspace:*",
    "@nimiplatform/sdk": "workspace:*",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.4.1",
    "@tauri-apps/plugin-fs": "^2.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "scheduler": "0.27.0",
    "zustand": "^5.0.12"
  }
}
