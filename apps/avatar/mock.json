{
  "scenario_id": "default",
  "version": "1",
  "description": "Default Phase 1 bootstrap scenario: cycles neutral → happy → greet → thinking to exercise NAS fallback motion group lookup and expression blending.",
  "duration_ms": 15000,
  "loop": true,

  "agent_bootstrap": {
    "active_world_id": "world-mock-default",
    "active_user_id": "user-mock-default",
    "locale": "zh-CN",
    "initial_posture": {
      "posture_class": "baseline_observer",
      "action_family": "observe",
      "interrupt_mode": "welcome",
      "transition_reason": "scenario_start",
      "truth_basis_ids": []
    },
    "initial_status_text": "在桌面上静静陪着你",
    "initial_execution_state": "IDLE"
  },

  "events": [
    {
      "kind": "time",
      "at_ms": 0,
      "type": "runtime.agent.presentation.activity_requested",
      "detail": {
        "activity_name": "neutral",
        "category": "emotion",
        "intensity": null,
        "source": "mock"
      }
    },
    {
      "kind": "time",
      "at_ms": 3000,
      "type": "runtime.agent.presentation.activity_requested",
      "detail": {
        "activity_name": "happy",
        "category": "emotion",
        "intensity": "moderate",
        "source": "mock"
      }
    },
    {
      "kind": "time",
      "at_ms": 6000,
      "type": "runtime.agent.presentation.activity_requested",
      "detail": {
        "activity_name": "greet",
        "category": "interaction",
        "intensity": null,
        "source": "mock"
      }
    },
    {
      "kind": "time",
      "at_ms": 10000,
      "type": "runtime.agent.presentation.activity_requested",
      "detail": {
        "activity_name": "thinking",
        "category": "interaction",
        "intensity": null,
        "source": "mock"
      }
    }
  ],

  "triggers": [
    {
      "trigger_id": "on-head-click-shy",
      "on": "avatar.user.click",
      "filter": { "region": "head" },
      "emit": {
        "type": "runtime.agent.presentation.activity_requested",
        "detail": {
          "activity_name": "shy",
          "category": "emotion",
          "intensity": "strong",
          "source": "mock"
        }
      }
    },
    {
      "trigger_id": "on-body-click-surprised",
      "on": "avatar.user.click",
      "filter": { "region": "body" },
      "emit": {
        "type": "runtime.agent.presentation.activity_requested",
        "detail": {
          "activity_name": "surprised",
          "category": "emotion",
          "intensity": "moderate",
          "source": "mock"
        }
      }
    }
  ]
}
