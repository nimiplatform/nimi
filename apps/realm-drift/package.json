{
  "name": "@nimiplatform/realm-drift",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:renderer": "vite --host 127.0.0.1 --port 1424 --strictPort",
    "dev:shell": "tauri dev --config src-tauri/tauri.conf.json",
    "build:renderer": "vite build",
    "typecheck": "tsc --noEmit",
    "build": "pnpm run typecheck && pnpm run build:renderer && (cd src-tauri && cargo check)",
    "lint": "pnpm run typecheck && eslint . --max-warnings 0 && (cd src-tauri && cargo check)",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^7.3.1",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@nimiplatform/nimi-kit": "workspace:*",
    "@nimiplatform/sdk": "workspace:*",
    "@tanstack/react-query": "^5.96.2",
    "@tauri-apps/api": "^2.10.1",
    "i18next": "^25.8.18",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-i18next": "^16.5.8",
    "react-router-dom": "^7.14.0",
    "socket.io-client": "^4.8.3",
    "zustand": "^5.0.12"
  }
}
