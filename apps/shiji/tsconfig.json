{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@renderer/*": ["src/shell/renderer/*"],
      "@engine/*": ["src/shell/renderer/engine/*"],
      "react": ["node_modules/@types/react/index.d.ts"],
      "react/jsx-runtime": ["node_modules/@types/react/jsx-runtime.d.ts"],
      "react-dom": ["node_modules/@types/react-dom/index.d.ts"],
      "react-dom/client": ["node_modules/@types/react-dom/client.d.ts"],
      "react-dom/server": ["node_modules/@types/react-dom/server.d.ts"],
      "@nimiplatform/sdk": ["../../sdk/src/index.ts"],
      "@nimiplatform/sdk/*": ["../../sdk/src/*"],
      "@nimiplatform/nimi-kit/features/model-picker": ["../../kit/features/model-picker/src/index.ts"],
      "@nimiplatform/nimi-kit/features/model-picker/*": ["../../kit/features/model-picker/src/*"],
      "@nimiplatform/nimi-kit/ui": ["../../kit/ui/src/index.ts"],
      "@nimiplatform/nimi-kit/ui/*": ["../../kit/ui/src/*"],
      "@nimiplatform/nimi-kit/auth": ["../../kit/auth/src/index.ts"],
      "@nimiplatform/nimi-kit/auth/*": ["../../kit/auth/src/*"],
      "@nimiplatform/nimi-kit/core": ["../../kit/core/src/index.ts"],
      "@nimiplatform/nimi-kit/core/*": ["../../kit/core/src/*"],
      "@nimiplatform/nimi-kit/telemetry": ["../../kit/telemetry/src/telemetry/index.ts"],
      "@nimiplatform/nimi-kit/telemetry/error-boundary": ["../../kit/telemetry/src/error-boundary/index.ts"]
    },
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "strictPropertyInitialization": true,
    "useUnknownInCatchVariables": true,
    "exactOptionalPropertyTypes": false,
    "noUncheckedIndexedAccess": true,
    "noPropertyAccessFromIndexSignature": false,
    "noEmit": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "types": ["node", "vite/client", "react", "react-dom"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "vite.config.ts",
    "../../kit/telemetry/src/telemetry/globals.d.ts"
  ]
}
