{
  "name": "@nimiplatform/overtone",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:renderer": "vite --host 127.0.0.1 --port 1421 --strictPort",
    "dev:shell": "tauri dev --config src-tauri/tauri.conf.json",
    "build:renderer": "vite build",
    "typecheck": "tsc --noEmit",
    "build": "pnpm run typecheck && pnpm run build:renderer && (cd src-tauri && cargo check)",
    "lint": "pnpm run typecheck && eslint . --max-warnings 0 && (cd src-tauri && cargo check)",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.4",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^7.3.1",
    "vitest": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "jsdom": "^28.1.0"
  },
  "dependencies": {
    "@nimiplatform/nimi-kit": "workspace:*",
    "@nimiplatform/sdk": "workspace:*",
    "@tanstack/react-query": "^5.100.5",
    "i18next": "^25.8.18",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-i18next": "^16.5.8",
    "react-router-dom": "^7.14.2",
    "zustand": "^5.0.12"
  }
}
