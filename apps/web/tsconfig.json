{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@renderer/infra/bootstrap/runtime-bootstrap": ["src/desktop-adapter/runtime-bootstrap.web.ts"],
      "@renderer/mod-ui/host/slot-host": ["src/desktop-adapter/slot-host.web.tsx"],
      "@renderer/mod-ui/host/slot-context": ["src/desktop-adapter/slot-context.web.ts"],
      "@renderer/features/mod-workspace/mod-workspace-tabs": ["src/desktop-adapter/mod-workspace-tabs.web.tsx"],
      "@renderer/features/runtime-config/runtime-config-panel-view": ["src/desktop-adapter/runtime-config-panel.web.tsx"],
      "@renderer/features/marketplace/marketplace-page": ["src/desktop-adapter/marketplace-page.web.tsx"],
      "@renderer/bridge": ["src/desktop-adapter/bridge.web.ts"],
      "@runtime/*": ["../desktop/src/runtime/*"],
      "@renderer/*": ["../desktop/src/shell/renderer/*"],
      "@mods/*": ["../desktop/src/mods/*"],
      "@nimiplatform/sdk": ["../../sdk/src/index.ts"],
      "@nimiplatform/sdk/*": ["../../sdk/src/*"],
      "@nimiplatform/shell-core/*": ["../_libs/shell-core/src/*"]
    },
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "strictPropertyInitialization": true,
    "useUnknownInCatchVariables": true,
    "exactOptionalPropertyTypes": false,
    "noUncheckedIndexedAccess": true,
    "noPropertyAccessFromIndexSignature": false,
    "noEmit": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "types": ["node"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "vite.config.ts",
    "../desktop/src/**/*.ts",
    "../desktop/src/**/*.tsx",
    "../../sdk/src/**/*.ts",
    "../../sdk/src/**/*.tsx",
    "../_libs/shell-core/src/**/*.ts"
  ]
}
