# Direct Seedance / Ark video smoke profile.
# The runner reads `.env` first and can also load this file via `--env-file`.

# Authentication: set one of these. The runner checks them in this order.
SEEDANCE_API_KEY=
ARK_API_KEY=
VOLCENGINE_API_KEY=

# Optional endpoint / model overrides.
SEEDANCE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
SEEDANCE_MODEL_ID=doubao-seedance-2-0-260128

# Optional smoke defaults.
SEEDANCE_SMOKE_SUBJECT_USER_ID=nimi-seedance-smoke
SEEDANCE_SMOKE_SCENARIO=minimal-t2v

# Optional direct envs reused by existing live tooling.
NIMI_LIVE_VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
NIMI_LIVE_VOLCENGINE_VIDEO_MODEL_ID=doubao-seedance-2-0-260128
