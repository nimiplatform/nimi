# ============================================================
# Provider Live Test Matrix — Environment Variables (YAML SSOT)
# ============================================================
# Copy to .env and fill API keys/model ids. Missing vars auto-skip tests.
# Run `pnpm live:audio-fixtures` to generate deterministic speech WAV files
# and print both local file paths and loopback URIs for speech fixtures.
# Run `pnpm run:ai-gold-path:dashscope` to execute the validated DashScope
# gold-path profile from `dev/config/dashscope-gold-path.env`.
# ============================================================

NIMI_LIVE_STT_AUDIO_PATH=
NIMI_LIVE_STT_AUDIO_URI=
NIMI_LIVE_VOICE_REFERENCE_AUDIO_PATH=
NIMI_LIVE_VOICE_REFERENCE_AUDIO_URI=
NIMI_LIVE_VOICE_CLONE_TEXT=
NIMI_LIVE_GOLD_SUBJECT_USER_ID=gold-user

