      "types": "./dist/ai-provider/index.d.ts",
      "default": "./dist/ai-provider/index.js"
    },
    "./mod/ai": {
      "types": "./dist/mod/ai/index.d.ts",
      "default": "./dist/mod/ai/index.js"
    },
    "./mod/hook": {
      "types": "./dist/mod/hook/index.d.ts",
      "default": "./dist/mod/hook/index.js"
    },
    "./mod/types": {
      "types": "./dist/mod/types/index.d.ts",
      "default": "./dist/mod/types/index.js"
    },
    "./mod/ui": {
      "types": "./dist/mod/ui.d.ts",
      "default": "./dist/mod/ui.js"
    },
    "./mod/logging": {
      "types": "./dist/mod/logging.d.ts",
