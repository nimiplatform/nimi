  "peerDependencies": {
    "react": "*"
  },
  "scripts": {
    "build": "node ../scripts/build-typescript-package.mjs --tsconfig tsconfig.build.json --out-dir dist",
    "lint": "tsc --noEmit",
    "test": "tsx --test test/**/*.test.ts"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.14",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
