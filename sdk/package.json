{
  "name": "@nimiplatform/sdk",
  "version": "0.4.77",
  "license": "Apache-2.0",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./realm": {
      "types": "./dist/realm/index.d.ts",
      "default": "./dist/realm/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "default": "./dist/runtime/index.js"
    },
    "./runtime/browser": {
      "types": "./dist/runtime/browser.d.ts",
      "default": "./dist/runtime/browser.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/types/index.js"
    },
    "./ai-provider": {
      "types": "./dist/ai-provider/index.d.ts",
      "default": "./dist/ai-provider/index.js"
    },
    "./mod": {
      "types": "./dist/mod/index.d.ts",
      "default": "./dist/mod/index.js"
    },
    "./mod/shell": {
      "types": "./dist/mod/shell.d.ts",
      "default": "./dist/mod/shell.js"
    },
    "./mod/lifecycle": {
      "types": "./dist/mod/lifecycle.d.ts",
      "default": "./dist/mod/lifecycle.js"
    },
    "./mod/storage": {
      "types": "./dist/mod/storage/index.d.ts",
      "default": "./dist/mod/storage/index.js"
    },
    "./scope": {
      "types": "./dist/scope/index.d.ts",
      "default": "./dist/scope/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@ai-sdk/provider": "^3.0.8",
    "@grpc/grpc-js": "^1.14.3",
    "@protobuf-ts/runtime": "2.11.1",
    "@protobuf-ts/runtime-rpc": "2.11.1",
    "i18next": "^25.8.18",
    "openapi-fetch": "^0.17.0",
    "react-i18next": "^16.5.8"
  },
  "peerDependencies": {
    "react": "*"
  },
  "scripts": {
    "build": "node ../scripts/build-typescript-package.mjs --tsconfig tsconfig.build.json --out-dir dist",
    "lint": "tsc --noEmit",
    "test": "tsx --test --test-concurrency=1 test/**/*.test.ts"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
