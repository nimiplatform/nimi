  "files": [
    "dist"
  ],
  "dependencies": {
    "@ai-sdk/provider": "^3.0.8",
    "@grpc/grpc-js": "^1.14.1",
    "@protobuf-ts/runtime": "2.11.1",
    "@protobuf-ts/runtime-rpc": "2.11.1",
    "i18next": "^25.8.11",
    "openapi-fetch": "^0.15.0",
    "react-i18next": "^16.5.4"
