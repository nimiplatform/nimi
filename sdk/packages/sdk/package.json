{
  "name": "@nimiplatform/sdk",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./realm": {
      "types": "./dist/realm.d.ts",
      "default": "./dist/realm.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "default": "./dist/runtime.js"
    },
    "./scope": {
      "types": "./dist/scope/index.d.ts",
      "default": "./dist/scope/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@nimiplatform/sdk-realm": "workspace:*",
    "@nimiplatform/sdk-runtime": "workspace:*",
    "@nimiplatform/sdk-types": "workspace:*"
  },
  "scripts": {
    "build": "node ../../../scripts/build-typescript-package.mjs --tsconfig tsconfig.build.json --out-dir dist",
    "lint": "tsc --noEmit",
    "test": "tsx --test test/**/*.test.ts"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
