# Nimi monorepo local development env template.
# Copy to `.env.local` (or export in shell) and adjust values per workspace.

# Desktop runtime mods discovery override (optional; CI/internal compatibility only).
NIMI_RUNTIME_MODS_DIR=/ABS/PATH/TO/runtime-mods
NIMI_RUNTIME_BRIDGE_MODE=RUNTIME

# Runtime/Realm connectivity (optional defaults shown).
# - Desktop runtime/data-sync directly uses NIMI_REALM_URL.
# - Web dev keeps same-origin requests and uses Vite proxy -> NIMI_REALM_URL.
NIMI_REALM_URL=http://localhost:3002
# Runtime control-plane base URL (policy/signature/grant/audit).
NIMI_CONTROL_PLANE_URL=http://localhost
# Web login launch base used by desktop browser-auth flow.
# If you run web dev locally, set this to your local web URL (for example http://127.0.0.1:3000).
NIMI_WEB_URL=http://localhost
NIMI_REALTIME_URL=
NIMI_ACCESS_TOKEN=

# Local AI runtime defaults.
NIMI_LOCAL_PROVIDER_ENDPOINT=http://127.0.0.1:1234/v1
NIMI_LOCAL_PROVIDER_MODEL=local-model
NIMI_LOCAL_OPENAI_ENDPOINT=http://127.0.0.1:1234/v1
NIMI_CREDENTIAL_REF_ID=
