# Nimi monorepo local development env template.
# Copy to `.env.local` (or export in shell) and adjust values per workspace.

# Desktop x external nimi-mods local joint-debug contract (required for dev shell/renderer with mods).
NIMI_MODS_ROOT=/ABS/PATH/TO/nimi-mods
NIMI_RUNTIME_MODS_DIR=/ABS/PATH/TO/nimi-mods

# Runtime/Realm connectivity (optional defaults shown).
NIMI_API_BASE_URL=http://localhost:3002
NIMI_REALTIME_URL=
NIMI_ACCESS_TOKEN=

# Local AI runtime defaults.
NIMI_LOCAL_PROVIDER_ENDPOINT=http://127.0.0.1:1234/v1
NIMI_LOCAL_PROVIDER_MODEL=local-model
NIMI_LOCAL_OPENAI_ENDPOINT=http://127.0.0.1:1234/v1
NIMI_LOCAL_OPENAI_API_KEY=
