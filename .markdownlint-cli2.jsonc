{
  "config": {
    "default": false,
    "MD009": true,
    "MD010": true,
    "MD012": true
  },
  "globs": [
    "**/*.md",
    "!**/node_modules/**",
    "!**/.git/**",
    "!_external/**",
    "!dev/report/**",
    "!dev/plan/**",
    "!**/dist/**",
    "!**/target/**",
    "!**/coverage/**"
  ]
}
