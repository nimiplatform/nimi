{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "types": ["node"]
  },
  "include": [
    "ui/src/**/*.ts",
    "ui/src/**/*.tsx",
    "ui/test/**/*.ts",
    "ui/test/**/*.tsx",
    "auth/src/**/*.ts",
    "auth/src/**/*.tsx",
    "auth/src/**/*.d.ts",
    "core/src/**/*.ts",
    "telemetry/src/**/*.ts",
    "telemetry/src/**/*.tsx",
    "telemetry/src/**/*.d.ts"
  ]
}
