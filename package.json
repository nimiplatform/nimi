    "check:no-local-ai-private-calls": "if ./scripts/rg.sh -n \"['\\\"]local_ai_[a-z0-9_]+['\\\"]\" apps/desktop/src --glob '*.{ts,tsx}'; then echo \"desktop TS private local_ai_* command literals are forbidden; use runtime.local.*\" && exit 1; else exit 0; fi",
    "check:no-local-ai-tauri-commands": "if ./scripts/rg.sh -n \"\\blocal_ai_[a-z0-9_]+\\b\" apps/desktop/src-tauri/src --glob '*.rs'; then echo \"desktop tauri local_ai_* command symbols are forbidden; use runtime bridge APIs\" && exit 1; else exit 0; fi",
    "check:desktop-no-legacy-runtime-config-path": "if ./scripts/rg.sh -n \"\\.nimi/runtime/config\\.json\" apps/desktop/src apps/desktop/src-tauri/src --glob '*.{ts,tsx,rs}'; then echo \"legacy desktop runtime config fallback path is forbidden; use .nimi/config.json only\" && exit 1; else exit 0; fi",
    "check:no-legacy-mod-permissions-field": "if ./scripts/rg.sh -n \"\\bpermissions\\s*:\" apps/desktop/src/runtime/mod apps/desktop/src/runtime/execution-kernel sdk/src/mod/types/runtime-mod.ts docs/guides/mod-developer.md --glob '*.{ts,tsx,md,yaml,yml}'; then echo \"legacy permissions field is forbidden in manifest/runtime registration; use capabilities\" && exit 1; else exit 0; fi",
    "check:no-nimid-doc-invocation": "if ./scripts/rg.sh -n \"go run \\./cmd/nimid\" docs README.md runtime/README.md; then echo \"legacy daemon invocation go run ./cmd/nimid is forbidden in docs; use go run ./cmd/nimi serve\" && exit 1; else exit 0; fi",
    "check:no-nimid-source": "if ./scripts/rg.sh -n \"cmd/nimid|\\bnimid\\b\" runtime sdk README.md CHANGELOG.md | ./scripts/rg.sh -v \"check:no-nimid-source\" | ./scripts/rg.sh -v \"check:no-nimid-doc-invocation\"; then echo \"legacy nimid entry/symbol is forbidden; use go run ./cmd/nimi serve\" && exit 1; else exit 0; fi",
