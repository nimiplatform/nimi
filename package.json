    "check:no-openapi-base-assignment": "if ./scripts/rg.sh -n \"OpenAPI\\.BASE\\s*=\" sdk apps examples scripts --glob '*.{ts,tsx,js,mjs,cjs}'; then echo \"OpenAPI.BASE assignment is forbidden; use Realm instance config\" && exit 1; else exit 0; fi",
    "check:no-openapi-token-assignment": "if ./scripts/rg.sh -n \"OpenAPI\\.TOKEN\\s*=\" sdk apps examples scripts --glob '*.{ts,tsx,js,mjs,cjs}'; then echo \"OpenAPI.TOKEN assignment is forbidden; use Realm instance config\" && exit 1; else exit 0; fi",
    "check:no-openapi-singleton-import": "if ./scripts/rg.sh -n \"import\\\\s*\\\\{[^}]*\\\\bOpenAPI\\\\b[^}]*\\\\}\\\\s*from\\\\s*['\\\"]@nimiplatform/sdk/realm['\\\"]\" sdk apps examples scripts --glob '*.{ts,tsx,js,mjs,cjs}'; then echo \"OpenAPI singleton import from @nimiplatform/sdk/realm is forbidden; use Realm instance\" && exit 1; else exit 0; fi",
